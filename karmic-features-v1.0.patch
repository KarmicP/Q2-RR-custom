index 00000000..21827403
--- /dev/null
+++ b/src/sgame/muffmode/mm_map_size_rules.h
@@ -0,0 +1,84 @@
+// Copyright (c) ZeniMax Media Inc.
+// Licensed under the GNU General Public License 2.0.
+
+#pragma once
+
+// Pure, host-testable map-rotation sizing rules.
+//
+// The next rotation map is chosen from size buckets gated by the number of human
+// players. Small is always eligible; Medium unlocks at >= medium_min humans;
+// Large at >= large_min. Smaller buckets stay eligible as the count rises
+// (additive). Engine-free by design so the host harness can compile it; the live
+// inputs (cvars, human count, RNG) and the intermission are supplied by
+// mm_maps.cpp.
+
+#include <algorithm>
+#include <cstddef>
+#include <cstdint>
+#include <string>
+#include <string_view>
+#include <vector>
+
+// ASCII case-insensitive equality (map tokens are ASCII).
+inline bool MM_MapTokenEqualsNoCase(std::string_view a, std::string_view b) {
+	if (a.size() != b.size())
+		return false;
+	for (size_t i = 0; i < a.size(); ++i) {
+		char ca = a[i], cb = b[i];
+		if (ca >= 'A' && ca <= 'Z') ca = static_cast<char>(ca - 'A' + 'a');
+		if (cb >= 'A' && cb <= 'Z') cb = static_cast<char>(cb - 'A' + 'a');
+		if (ca != cb)
+			return false;
+	}
+	return true;
+}
+
+// True when a bucket with the given unlock threshold is eligible at `humans`.
+inline bool MM_MapSizeBucketUnlocked(int humans, int min_humans) {
+	return humans >= min_humans;
+}
+
+// Build the eligible token set for the current human count:
+//  - Small always; Medium if humans >= medium_min; Large if humans >= large_min.
+//  - Deduplicate tokens shared across buckets.
+//  - Remove the current map to avoid an immediate repeat, but only when at least
+//    one other map remains (a single-map result keeps that map).
+// Returns the eligible tokens (possibly empty -> caller falls back to g_map_list).
+inline std::vector<std::string> MM_BuildEligibleSizedMaps(
+	int humans,
+	int medium_min,
+	int large_min,
+	const std::vector<std::string> &small,
+	const std::vector<std::string> &medium,
+	const std::vector<std::string> &large,
+	std::string_view current_map)
+{
+	std::vector<std::string> eligible(small.begin(), small.end());
+	if (MM_MapSizeBucketUnlocked(humans, medium_min))
+		eligible.insert(eligible.end(), medium.begin(), medium.end());
+	if (MM_MapSizeBucketUnlocked(humans, large_min))
+		eligible.insert(eligible.end(), large.begin(), large.end());
+
+	std::sort(eligible.begin(), eligible.end());
+	eligible.erase(std::unique(eligible.begin(), eligible.end()), eligible.end());
+
+	if (eligible.size() > 1) {
+		std::vector<std::string> without_current;
+		without_current.reserve(eligible.size());
+		for (const std::string &m : eligible)
+			if (!MM_MapTokenEqualsNoCase(m, current_map))
+				without_current.push_back(m);
+		if (!without_current.empty())
+			eligible.swap(without_current);
+	}
+
+	return eligible;
+}
+
+// Deterministic pick: index into `eligible` for the given rng value, or SIZE_MAX
+// when empty. Engine passes mt_rand(); tests pass fixed values.
+inline size_t MM_PickEligibleIndex(size_t eligible_size, uint32_t rng_value) {
+	if (eligible_size == 0)
+		return SIZE_MAX;
+	return static_cast<size_t>(rng_value % eligible_size);
+}
