+// Copyright (c) ZeniMax Media Inc.
+// Licensed under the GNU General Public License 2.0.
+
+#pragma once
+
+// Cross-session player leaderboard. Persisted to baseq2/ranks.cfg, keyed by
+// social_id. Elo + lifetime totals update once per finished match from the
+// human roster (bots never rank). Pure math/record logic lives in
+// mm_ranks_rules.h; this is the live glue used by Match_End and the in-game
+// leaderboard menu.
+
+#include <cstddef>
+#include <string>
+#include <vector>
+
+struct gentity_t;
+
+// Load ranks from disk. Called once from InitGame().
+void MM_Ranks_Load();
+
+// Fold the just-finished match into the leaderboard and persist. Ranked only
+// when >= 2 human players took part; bots and spectators are ignored.
+void MM_Ranks_RecordMatch();
+
+// Number of ranked players on record.
+size_t MM_Ranks_Count();
+
+// Fill `out` with up to `count` formatted leaderboard rows (highest Elo first),
+// e.g. " 1. Xaero            1487  60W". Used by the `leaderboard` console command.
+void MM_Ranks_TopLines(int count, std::vector<std::string> &out);
+
+// Fill `out` with up to `count` all-time-scoreboard rows: rank, name, Elo, K/D.
+// Used by the in-game "All-Time Scoreboard" menu.
+void MM_Ranks_ScoreLines(int count, std::vector<std::string> &out);
diff --git a/src/sgame/muffmode/mm_ranks_rules.h b/src/sgame/muffmode/mm_ranks_rules.h
new file mode 100644
index 00000000..372513cb
--- /dev/null
+++ b/src/sgame/muffmode/mm_ranks_rules.h
@@ -0,0 +1,208 @@
+// Copyright (c) ZeniMax Media Inc.
+// Licensed under the GNU General Public License 2.0.
+
+#pragma once
+
+// Pure, host-testable player-ranking rules for the cross-session leaderboard.
+//
+// One record per player, keyed by social_id, persisted one-per-line as:
+//     social_id|name|elo|matches|wins|kills|deaths
+// Elo starts at k_elo_start and updates per match via pairwise comparison of the
+// human players' placements (bots never rank -> never passed in). Engine-free:
+// mm_ranks.cpp supplies file I/O, the live match roster, and the menu.
+
+#include <algorithm>
+#include <cmath>
+#include <cstddef>
+#include <string>
+#include <string_view>
+#include <vector>
+
+namespace muffmode::ranks {
+
+constexpr int k_elo_start = 1000;
+constexpr int k_elo_kfactor = 16;
+constexpr int k_elo_spread_cap = 200; // clamp rating diff before expectation
+
+struct RankRecord {
+	std::string social_id;
+	std::string name;
+	int elo = k_elo_start;
+	int matches = 0;
+	int wins = 0;
+	int kills = 0;
+	int deaths = 0;
+};
+
+// One player's line in a finished match: their rating going in and final place
+// (1 = winner). Ties share a place.
+struct MatchStanding {
+	int elo;
+	int place;
+};
+
+inline std::string SanitizeField(std::string_view in) {
+	std::string out;
+	out.reserve(in.size());
+	for (char c : in)
+		out.push_back((c == '|' || c == '\n' || c == '\r') ? ' ' : c);
+	return out;
+}
+
+inline std::string FormatRankLine(const RankRecord &r) {
+	return SanitizeField(r.social_id) + "|" + SanitizeField(r.name) + "|" +
+		std::to_string(r.elo) + "|" + std::to_string(r.matches) + "|" +
+		std::to_string(r.wins) + "|" + std::to_string(r.kills) + "|" + std::to_string(r.deaths);
+}
+
+// Parse "social_id|name|elo|matches|wins|kills|deaths". Missing trailing fields
+// default. Returns false for blank/comment lines or an empty social_id.
+inline bool ParseRankLine(std::string_view line, RankRecord &out) {
+	size_t start = 0;
+	while (start < line.size() && (line[start] == ' ' || line[start] == '\t'))
+		++start;
+	line.remove_prefix(start);
+	if (line.empty() || line[0] == '#')
+		return false;
+
+	std::vector<std::string_view> f;
+	size_t pos = 0;
+	while (true) {
+		size_t bar = line.find('|', pos);
+		f.push_back(line.substr(pos, bar == std::string_view::npos ? std::string_view::npos : bar - pos));
+		if (bar == std::string_view::npos)
+			break;
+		pos = bar + 1;
+	}
+	if (f.empty() || f[0].empty())
+		return false;
+
+	auto to_int = [](std::string_view s, int def) {
+		int v = 0;
+		bool neg = false, any = false;
+		size_t i = 0;
+		if (i < s.size() && (s[i] == '-' || s[i] == '+')) { neg = s[i] == '-'; ++i; }
+		for (; i < s.size(); ++i) {
+			if (s[i] < '0' || s[i] > '9') return def;
+			v = v * 10 + (s[i] - '0');
+			any = true;
+		}
+		return any ? (neg ? -v : v) : def;
+	};
+
+	out = RankRecord{};
+	out.social_id = std::string(f[0]);
+	if (f.size() > 1) out.name = std::string(f[1]);
+	if (f.size() > 2) out.elo = to_int(f[2], k_elo_start);
+	if (f.size() > 3) out.matches = to_int(f[3], 0);
+	if (f.size() > 4) out.wins = to_int(f[4], 0);
+	if (f.size() > 5) out.kills = to_int(f[5], 0);
+	if (f.size() > 6) out.deaths = to_int(f[6], 0);
+	return true;
+}
+
+inline size_t FindRankIndex(const std::vector<RankRecord> &list, std::string_view social_id) {
+	for (size_t i = 0; i < list.size(); ++i)
+		if (list[i].social_id == social_id)
+			return i;
+	return static_cast<size_t>(-1);
+}
+
+// Return the record for social_id, creating a fresh one (elo = start) if absent.
+inline RankRecord &FindOrCreate(std::vector<RankRecord> &list, std::string_view social_id, std::string_view name) {
+	size_t idx = FindRankIndex(list, social_id);
+	if (idx == static_cast<size_t>(-1)) {
+		RankRecord r;
+		r.social_id = std::string(social_id);
+		r.name = std::string(name);
+		list.push_back(r);
+		return list.back();
+	}
+	if (!name.empty())
+		list[idx].name = std::string(name); // keep last-seen name fresh
+	return list[idx];
+}
+
+// Fold one match result into a player's lifetime totals (Elo handled separately).
+inline void MergeMatch(RankRecord &r, int kills, int deaths, bool win) {
+	r.matches += 1;
+	r.wins += win ? 1 : 0;
+	r.kills += kills;
+	r.deaths += deaths;
+}
+
+// Expected score of A vs B (0..1). Rating diff is clamped to +/- spread cap so a
+// single lopsided matchup can't swing ratings wildly.
+inline double EloExpected(int elo_a, int elo_b) {
+	int diff = elo_b - elo_a;
+	if (diff > k_elo_spread_cap) diff = k_elo_spread_cap;
+	if (diff < -k_elo_spread_cap) diff = -k_elo_spread_cap;
+	return 1.0 / (1.0 + std::pow(10.0, diff / 400.0));
+}
+
+// Compute integer Elo deltas for a match. Each player is compared pairwise to
+// every other: actual = 1 if they placed better, 0.5 tie, 0 worse. Returns one
+// delta per standing (same order). Fewer than 2 players -> all zero.
+inline std::vector<int> ComputeEloDeltas(const std::vector<MatchStanding> &standings) {
+	std::vector<int> deltas(standings.size(), 0);
+	if (standings.size() < 2)
+		return deltas;
+	for (size_t i = 0; i < standings.size(); ++i) {
+		double sum = 0.0;
+		for (size_t j = 0; j < standings.size(); ++j) {
+			if (i == j)
+				continue;
+			double actual = standings[i].place < standings[j].place ? 1.0
+				: (standings[i].place == standings[j].place ? 0.5 : 0.0);
+			sum += actual - EloExpected(standings[i].elo, standings[j].elo);
+		}
+		deltas[i] = static_cast<int>(std::lround(k_elo_kfactor * sum));
+	}
+	return deltas;
+}
+
+// Leaderboard order: Elo desc, then wins desc, then name asc for stability.
+inline std::vector<const RankRecord *> Leaderboard(const std::vector<RankRecord> &list) {
+	std::vector<const RankRecord *> out;
+	out.reserve(list.size());
+	for (const RankRecord &r : list)
+		out.push_back(&r);
+	std::sort(out.begin(), out.end(), [](const RankRecord *a, const RankRecord *b) {
+		if (a->elo != b->elo) return a->elo > b->elo;
+		if (a->wins != b->wins) return a->wins > b->wins;
+		return a->name < b->name;
+	});
+	return out;
+}
+
+inline std::string FormatRankFile(const std::vector<RankRecord> &list) {
+	std::string out;
+	for (const RankRecord &r : list) {
+		out += FormatRankLine(r);
+		out.push_back('\n');
+	}
+	return out;
+}
+
+inline std::vector<RankRecord> ParseRankFile(std::string_view text) {
+	std::vector<RankRecord> list;
+	size_t pos = 0;
+	while (pos <= text.size()) {
+		size_t nl = text.find('\n', pos);
+		std::string_view line = text.substr(pos, nl == std::string_view::npos ? std::string_view::npos : nl - pos);
+		if (!line.empty() && line.back() == '\r')
+			line.remove_suffix(1);
+		RankRecord r;
+		if (ParseRankLine(line, r)) {
+			size_t idx = FindRankIndex(list, r.social_id);
+			if (idx == static_cast<size_t>(-1)) list.push_back(r);
+			else list[idx] = r; // last wins on dupe
+		}
+		if (nl == std::string_view::npos)
+			break;
+		pos = nl + 1;
+	}
+	return list;
+}
+
+} // namespace muffmode::ranks
