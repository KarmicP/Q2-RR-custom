+// [KarmicP] Set the fallback map (g_default_map) and persist it to
+// defaultmap.cfg. Does NOT change the current map.
+static void Cmd_DefaultMap_f(gentity_t *ent) {
+	if (gi.argc() < 2) {
+		gi.LocClient_Print(ent, PRINT_HIGH, "Default map is \"{}\".\n", muffmode::CvarString(g_default_map));
+		return;
+	}
+	const char *token = gi.argv(1);
+	if (!MM_IsSafeMapToken(token)) {
+		gi.LocClient_Print(ent, PRINT_HIGH, "Invalid map token.\n");
+		return;
+	}
+	gi.cvar_forceset("g_default_map", token);
+	MM_DefaultMap_Save(token);
+	gi.LocBroadcast_Print(PRINT_HIGH, "Default map set to {} (saved).\n", token);
+}
+
+// [KarmicP] Ban the player in the given slot by social_id, then kick them.
+static void Cmd_Ban_f(gentity_t *ent) {
+	if (gi.argc() < 2) {
+		gi.LocClient_Print(ent, PRINT_HIGH, "Usage: {} [client number] [reason]\n", gi.argv(0));
+		return;
+	}
+
+	if (*gi.argv(1) < '0' || *gi.argv(1) > '9') {
+		gi.LocClient_Print(ent, PRINT_HIGH, "Specify the player number to ban.\n");
+		return;
+	}
+
+	gentity_t *targ = ClientEntFromString(gi.argv(1));
+	if (targ == nullptr || !targ->inuse || !targ->client) {
+		gi.LocClient_Print(ent, PRINT_HIGH, "Invalid client number.\n");
+		return;
+	}
+
+	if (targ == &g_entities[1]) {
+		gi.LocClient_Print(ent, PRINT_HIGH, "You cannot ban the lobby owner.\n");
+		return;
+	}
+
+	if (targ->client->sess.admin) {
+		gi.LocClient_Print(ent, PRINT_HIGH, "You cannot ban an admin.\n");
+		return;
+	}
+
+	std::string reason;
+	for (int i = 2; i < gi.argc(); ++i) {
+		if (!reason.empty())
+			reason += ' ';
+		reason += gi.argv(i);
+	}
+
+	const char *sid = targ->client->pers.social_id;
+	if (targ->client->sess.is_a_bot || sid == nullptr || sid[0] == '\0') {
+		gi.LocClient_Print(ent, PRINT_HIGH, "That player has no social ID (bot or unauthenticated); kicking instead.\n");
+		gi.AddCommandString(G_Fmt("kick {}\n", targ - g_entities).data());
+		return;
+	}
+
+	MM_Bans_Add(sid, targ->client->resp.netname, reason);
+	gi.LocBroadcast_Print(PRINT_HIGH, "{} was banned.\n", targ->client->resp.netname);
+	gi.AddCommandString(G_Fmt("kick {}\n", targ - g_entities).data());
+}
+
+// [KarmicP] Remove a ban by social_id (from 'banlist').
+static void Cmd_Unban_f(gentity_t *ent) {
+	if (gi.argc() < 2) {
+		gi.LocClient_Print(ent, PRINT_HIGH, "Usage: {} [social_id]  (see 'banlist')\n", gi.argv(0));
+		return;
+	}
+
+	if (MM_Bans_Remove(gi.argv(1)))
+		gi.LocClient_Print(ent, PRINT_HIGH, "Removed ban for {}.\n", gi.argv(1));
+	else
+		gi.LocClient_Print(ent, PRINT_HIGH, "No ban found for {}.\n", gi.argv(1));
+}
+
+// [KarmicP] Print the ban list.
+static void Cmd_BanList_f(gentity_t *ent) {
+	MM_Bans_Print(ent);
+}
+
+// [KarmicP] Print the cross-session leaderboard (top players by Elo).
+static void Cmd_Leaderboard_f(gentity_t *ent) {
+	std::vector<std::string> lines;
+	MM_Ranks_TopLines(15, lines);
+	if (lines.empty()) {
+		gi.LocClient_Print(ent, PRINT_HIGH, "No ranked matches yet.\n");
+		return;
+	}
+	gi.LocClient_Print(ent, PRINT_HIGH, "-- Server Leaderboard --\n");
+	for (const std::string &line : lines)
+		gi.LocClient_Print(ent, PRINT_HIGH, "{}\n", line.c_str());
+}
