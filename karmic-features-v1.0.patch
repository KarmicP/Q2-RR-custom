 	if (GT(GT_HORDE) && g_horde_tech_reset_each_wave->integer)
 		return;
 
+	// [KarmicP] Cancel any still-pending tech spawner before scheduling a new one.
+	// The map-load spawn schedules Tech_SpawnAll on a 2s delay; with instant-start
+	// configs (g_dm_do_warmup 0) Match_Start's Tech_Reset() runs inside that window,
+	// and since no techs have spawned yet it frees nothing and would add a SECOND
+	// spawner -> 2 of each tech a few feet apart. Deduping keeps it at one of each.
+	for (gentity_t *e = g_entities + 1, *end = g_entities + globals.num_entities; e < end; ++e)
+		if (e->inuse && e->think == Tech_SpawnAll)
+			G_FreeEntity(e);
+
 	gentity_t *ent = G_Spawn();
 	ent->nextthink = level.time + 2_sec;
 	ent->think = Tech_SpawnAll;
