+/*
+================
+TickBotFill  [KarmicP]
+
+Once g_bot_human_cutoff connected humans are present, force bot_minClients to 0
+and kick every bot so the game is human-only; below the cutoff, restore the
+server's original fill so bots return. Throttled to once a second — kicks are
+queued via AddCommandString, so re-running while bots are already gone is a
+no-op. See mm_bots_rules.h for the pure decision.
+================
+*/
+static void TickBotFill() {
+	if (!g_bot_human_cutoff || g_bot_human_cutoff->integer <= 0)
+		return;
+
+	static gtime_t next_check = 0_ms;
+	static int cached_fill = 0; // last non-zero bot_minClients we saw
+
+	if (level.time < next_check)
+		return;
+	next_check = level.time + 1_sec;
+
+	int humans = 0;
+	for (auto ec : active_clients()) {
+		if (ec->client->sess.is_a_bot || (ec->svflags & SVF_BOT))
+			continue;
+		if (!ClientIsPlaying(ec->client)) // only count humans in the match, not spectators
+			continue;
+		humans++;
+	}
+
+	cvar_t *bot_fill = gi.cvar("bot_minClients", "0", CVAR_NOFLAGS);
+
+	MM_BotFillDecision d = MM_DecideBotFill(humans, g_bot_human_cutoff->integer, bot_fill->integer, cached_fill);
+	cached_fill = d.cached_fill;
+
+	if (d.update_fill)
+		gi.cvar_forceset("bot_minClients", G_Fmt("{}", d.fill_value).data());
+
+	if (d.kick_bots) {
+		for (auto ec : active_clients())
+			if (ec->client->sess.is_a_bot || (ec->svflags & SVF_BOT))
+				gi.AddCommandString(G_Fmt("kick {}\n", ec - g_entities).data());
+	}
+}
