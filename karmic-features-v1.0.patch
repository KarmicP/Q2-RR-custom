new file mode 100644
index 00000000..94a9e573
--- /dev/null
+++ b/src/sgame/muffmode/mm_ranks.cpp
@@ -0,0 +1,148 @@
+// Copyright (c) ZeniMax Media Inc.
+// Licensed under the GNU General Public License 2.0.
+
+#include "g_local.h"
+#include "muffmode/mm_ranks.h"
+#include "muffmode/mm_ranks_rules.h"
+
+#include <filesystem>
+#include <fstream>
+#include <iterator>
+#include <string>
+#include <vector>
+
+namespace {
+
+constexpr const char *k_rank_file = "baseq2/ranks.cfg";
+
+std::vector<muffmode::ranks::RankRecord> g_ranks;
+
+bool ReadFileText(const std::filesystem::path &path, std::string &out) {
+	std::error_code ec;
+	if (!std::filesystem::exists(path, ec))
+		return false;
+	std::ifstream in(path, std::ios::binary);
+	if (!in)
+		return false;
+	out.assign(std::istreambuf_iterator<char>(in), std::istreambuf_iterator<char>());
+	return true;
+}
+
+bool WriteRankFile() {
+	const std::filesystem::path path(k_rank_file);
+	const std::filesystem::path tmp = std::filesystem::path(std::string(k_rank_file) + ".tmp");
+	std::error_code ec;
+	std::filesystem::create_directories(path.parent_path(), ec);
+	{
+		std::ofstream out(tmp, std::ios::binary | std::ios::trunc);
+		if (!out)
+			return false;
+		const std::string text = muffmode::ranks::FormatRankFile(g_ranks);
+		out.write(text.data(), static_cast<std::streamsize>(text.size()));
+		if (!out.good())
+			return false;
+	}
+	std::filesystem::rename(tmp, path, ec);
+	if (ec) {
+		std::filesystem::remove(path, ec);
+		std::filesystem::rename(tmp, path, ec);
+	}
+	return !ec;
+}
+
+} // namespace
+
+void MM_Ranks_Load() {
+	g_ranks.clear();
+	std::string text;
+	if (ReadFileText(k_rank_file, text))
+		g_ranks = muffmode::ranks::ParseRankFile(text);
+	gi.Com_PrintFmt("MuffMode: loaded {} ranked player(s) from {}\n", g_ranks.size(), k_rank_file);
+}
+
+size_t MM_Ranks_Count() {
+	return g_ranks.size();
+}
+
+void MM_Ranks_RecordMatch() {
+	struct Live {
+		std::string sid, name;
+		int score = 0, kills = 0, deaths = 0, place = 1, elo = muffmode::ranks::k_elo_start;
+	};
+
+	std::vector<Live> live;
+	for (int i = 1; i <= static_cast<int>(game.maxclients); ++i) {
+		gentity_t *ec = &g_entities[i];
+		if (!ec->inuse || !ec->client)
+			continue;
+		if (ec->client->sess.is_a_bot)
+			continue; // bots never rank
+		if (!ClientIsPlaying(ec->client))
+			continue; // skip spectators
+		const char *sid = ec->client->pers.social_id;
+		if (sid == nullptr || sid[0] == '\0')
+			continue; // no stable identity -> skip
+
+		Live L;
+		L.sid = sid;
+		L.name = ec->client->resp.netname;
+		L.score = ec->client->resp.score;
+		L.kills = MS_Value(ec->client, MSTAT_KILLS_TOTAL);
+		L.deaths = MS_Value(ec->client, MSTAT_DEATHS_TOTAL);
+		const size_t idx = muffmode::ranks::FindRankIndex(g_ranks, L.sid);
+		L.elo = (idx == static_cast<size_t>(-1)) ? muffmode::ranks::k_elo_start : g_ranks[idx].elo;
+		live.push_back(std::move(L));
+	}
+
+	if (live.size() < 2)
+		return; // a ranked match needs >= 2 human players
+
+	// Placement by score; equal scores share a place.
+	for (Live &L : live) {
+		int better = 0;
+		for (const Live &O : live)
+			if (O.score > L.score)
+				++better;
+		L.place = better + 1;
+	}
+
+	std::vector<muffmode::ranks::MatchStanding> standings;
+	standings.reserve(live.size());
+	for (const Live &L : live)
+		standings.push_back({ L.elo, L.place });
+	const std::vector<int> deltas = muffmode::ranks::ComputeEloDeltas(standings);
+
+	for (size_t i = 0; i < live.size(); ++i) {
+		muffmode::ranks::RankRecord &r = muffmode::ranks::FindOrCreate(g_ranks, live[i].sid, live[i].name);
+		muffmode::ranks::MergeMatch(r, live[i].kills, live[i].deaths, live[i].place == 1);
+		r.elo += deltas[i];
+		if (r.elo < 100)
+			r.elo = 100;
+	}
+
+	WriteRankFile();
+	gi.Com_PrintFmt("MuffMode: recorded ranked match for {} player(s)\n", live.size());
+}
+
+void MM_Ranks_TopLines(int count, std::vector<std::string> &out) {
+	const std::vector<const muffmode::ranks::RankRecord *> lb = muffmode::ranks::Leaderboard(g_ranks);
+	int n = 0;
+	for (const muffmode::ranks::RankRecord *r : lb) {
+		if (n >= count)
+			break;
+		out.push_back(G_Fmt("{:2}. {:<12.12} {:>4}", n + 1, r->name, r->elo).data());
+		++n;
+	}
+}
+
+void MM_Ranks_ScoreLines(int count, std::vector<std::string> &out) {
+	const std::vector<const muffmode::ranks::RankRecord *> lb = muffmode::ranks::Leaderboard(g_ranks);
+	int n = 0;
+	for (const muffmode::ranks::RankRecord *r : lb) {
+		if (n >= count)
+			break;
+		const double kd = r->deaths > 0 ? static_cast<double>(r->kills) / r->deaths : static_cast<double>(r->kills);
+		out.push_back(G_Fmt("{:2}.{:<11.11}{:>4}{:>6.2f}", n + 1, r->name, r->elo, kd).data());
+		++n;
+	}
+}
