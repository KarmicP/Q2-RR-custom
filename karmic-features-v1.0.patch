+// [MuffMode local patch] Human-count-based map sizing — engine glue.
+static int MM_CountHumans()
+{
+	int humans = 0;
+	for (uint32_t i = 1; i <= game.maxclients; i++) {
+		gentity_t *ent = &g_entities[i];
+		if (!ent->inuse || !ent->client)
+			continue;
+		if (!ent->client->pers.connected)
+			continue;
+		if (ent->client->sess.is_a_bot || (ent->svflags & SVF_BOT))
+			continue;
+		humans++;
+	}
+	return humans;
+}
+
+static std::vector<std::string> MM_TokenizePool(cvar_t *pool)
+{
+	std::vector<std::string> out;
+	if (!pool || !muffmode::CvarString(pool)[0])
+		return out;
+
+	const char *str = muffmode::CvarString(pool);
+	const char *tok;
+	while ((tok = muffmode::maps::ParseNextSafeMapToken(&str)) != nullptr && *tok)
+		out.emplace_back(tok);
+	return out;
+}
+
+std::string MM_SelectSizedMap()
+{
+	if (!muffmode::CvarInteger(g_map_size_logic))
+		return "";
+
+	const int humans = MM_CountHumans();
+	std::vector<std::string> eligible = MM_BuildEligibleSizedMaps(
+		humans,
+		muffmode::CvarInteger(g_map_medium_min),
+		muffmode::CvarInteger(g_map_large_min),
+		MM_TokenizePool(g_map_pool_small),
+		MM_TokenizePool(g_map_pool_medium),
+		MM_TokenizePool(g_map_pool_large),
+		level.mapname);
+
+	const size_t idx = MM_PickEligibleIndex(eligible.size(), static_cast<uint32_t>(mt_rand()));
+	if (idx == SIZE_MAX)
+		return ""; // disabled handled above; here means no eligible maps -> fall back
+
+	MuffModeLog("MAP", "Size logic: %d humans, %d eligible, picked '%s'",
+		humans, static_cast<int>(eligible.size()), eligible[idx].c_str());
+	return eligible[idx];
+}
