+// [KarmicP] Persist the admin's default-map choice to baseq2/defaultmap.cfg
+// (atomic temp+rename), mirroring the bans/ranks files. Written as exec-style
+// lines: the `set` line is parsed back by MM_DefaultMap_Load at InitGame, and
+// the `map` boot line makes `exec defaultmap.cfg` (issued by net.cfg after its
+// fallback `map`) boot the server into the saved pick. Saving here does NOT
+// change the current map.
+void MM_DefaultMap_Save(const char *token)
+{
+	if (!token)
+		token = "";
+	const char *k_default_map_file = "baseq2/defaultmap.cfg";
+	const std::filesystem::path path(k_default_map_file);
+	const std::filesystem::path tmp = std::filesystem::path(std::string(k_default_map_file) + ".tmp");
+	std::error_code ec;
+	std::filesystem::create_directories(path.parent_path(), ec);
+	{
+		std::ofstream out(tmp, std::ios::binary | std::ios::trunc);
+		if (!out)
+			return;
+		out << "set g_default_map \"" << token << "\"\n";
+		if (*token)
+			out << "map \"" << token << "\"\n";
+		if (!out.good())
+			return;
+	}
+	std::filesystem::rename(tmp, path, ec);
+	if (ec) {
+		// Windows rename fails if the target exists; replace it explicitly.
+		std::filesystem::remove(path, ec);
+		std::filesystem::rename(tmp, path, ec);
+	}
+}
+
+// [KarmicP] Load the persisted default map at InitGame and apply it to
+// g_default_map, overriding the net.cfg default so the admin's saved choice
+// wins. Missing/blank/unsafe -> leave g_default_map as configured.
+void MM_DefaultMap_Load()
+{
+	const char *k_default_map_file = "baseq2/defaultmap.cfg";
+	std::error_code ec;
+	if (!std::filesystem::exists(k_default_map_file, ec))
+		return;
+	std::ifstream in(k_default_map_file, std::ios::binary);
+	if (!in)
+		return;
+	std::string contents((std::istreambuf_iterator<char>(in)), std::istreambuf_iterator<char>());
+	std::string token = MM_ParseDefaultMapConfig(contents);
+	if (token.empty() || !MM_IsSafeMapToken(token.c_str()))
+		return;
+	gi.cvar_forceset("g_default_map", token.c_str());
+	gi.Com_PrintFmt("MuffMode: default map '{}' loaded from {}\n", token, k_default_map_file);
+}
