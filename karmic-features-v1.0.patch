diff --git a/src/sgame/muffmode/mm_bans_rules.h b/src/sgame/muffmode/mm_bans_rules.h
new file mode 100644
index 00000000..f3193cf9
--- /dev/null
+++ b/src/sgame/muffmode/mm_bans_rules.h
@@ -0,0 +1,142 @@
+// Copyright (c) ZeniMax Media Inc.
+// Licensed under the GNU General Public License 2.0.
+
+#pragma once
+
+// Pure, host-testable ban-list rules.
+//
+// Bans are keyed by the engine-provided social_id (stable per platform account,
+// unlike name or IP). The persisted form is one record per line:
+//     social_id|name|reason
+// Fields are pipe-delimited; '|' and newlines are stripped from name/reason on
+// write so a record is always exactly one line. Engine-free by design: the live
+// file I/O, connect-time enforcement, and admin commands live in mm_bans.cpp.
+
+#include <cstddef>
+#include <string>
+#include <string_view>
+#include <vector>
+
+namespace muffmode::bans {
+
+struct BanRecord {
+	std::string social_id;
+	std::string name;   // last-seen display name (informational)
+	std::string reason; // admin-supplied, may be empty
+};
+
+// Replace field separators / newlines so a value never breaks the line format.
+inline std::string SanitizeField(std::string_view in) {
+	std::string out;
+	out.reserve(in.size());
+	for (char c : in) {
+		if (c == '|' || c == '\n' || c == '\r')
+			out.push_back(' ');
+		else
+			out.push_back(c);
+	}
+	return out;
+}
+
+// Serialize one record to its single-line persisted form.
+inline std::string FormatBanLine(const BanRecord &rec) {
+	return SanitizeField(rec.social_id) + "|" + SanitizeField(rec.name) + "|" + SanitizeField(rec.reason);
+}
+
+// Parse one persisted line. Returns false for blank/comment lines or a record
+// with an empty social_id (the required key). Extra '|' beyond the third field
+// are folded into the reason.
+inline bool ParseBanLine(std::string_view line, BanRecord &out) {
+	// trim leading whitespace
+	size_t start = 0;
+	while (start < line.size() && (line[start] == ' ' || line[start] == '\t'))
+		++start;
+	line.remove_prefix(start);
+	if (line.empty() || line[0] == '#')
+		return false;
+
+	const size_t p1 = line.find('|');
+	std::string_view id = line.substr(0, p1);
+	if (id.empty())
+		return false;
+
+	out = BanRecord{};
+	out.social_id = std::string(id);
+	if (p1 == std::string_view::npos)
+		return true;
+
+	std::string_view rest = line.substr(p1 + 1);
+	const size_t p2 = rest.find('|');
+	out.name = std::string(rest.substr(0, p2));
+	if (p2 != std::string_view::npos)
+		out.reason = std::string(rest.substr(p2 + 1));
+	return true;
+}
+
+// social_id comparison is exact (platform ids are opaque, case-sensitive).
+inline size_t FindBanIndex(const std::vector<BanRecord> &list, std::string_view social_id) {
+	for (size_t i = 0; i < list.size(); ++i)
+		if (list[i].social_id == social_id)
+			return i;
+	return static_cast<size_t>(-1);
+}
+
+inline bool IsBanned(const std::vector<BanRecord> &list, std::string_view social_id) {
+	return !social_id.empty() && FindBanIndex(list, social_id) != static_cast<size_t>(-1);
+}
+
+// Add a ban, or update the name/reason of an existing one (dedupe by social_id).
+// Returns true if a new record was added, false if an existing one was updated.
+// An empty social_id is rejected (returns false, list unchanged).
+inline bool AddOrUpdateBan(std::vector<BanRecord> &list, const BanRecord &rec) {
+	if (rec.social_id.empty())
+		return false;
+	const size_t idx = FindBanIndex(list, rec.social_id);
+	if (idx != static_cast<size_t>(-1)) {
+		list[idx].name = rec.name;
+		list[idx].reason = rec.reason;
+		return false;
+	}
+	list.push_back(rec);
+	return true;
+}
+
+// Remove a ban by social_id. Returns true if a record was removed.
+inline bool RemoveBan(std::vector<BanRecord> &list, std::string_view social_id) {
+	const size_t idx = FindBanIndex(list, social_id);
+	if (idx == static_cast<size_t>(-1))
+		return false;
+	list.erase(list.begin() + static_cast<std::ptrdiff_t>(idx));
+	return true;
+}
+
+// Serialize the whole list to file text (one record per line, trailing newline).
+inline std::string FormatBanFile(const std::vector<BanRecord> &list) {
+	std::string out;
+	for (const BanRecord &rec : list) {
+		out += FormatBanLine(rec);
+		out.push_back('\n');
+	}
+	return out;
+}
+
+// Parse whole-file text into records (skips blank/comment/invalid lines).
+inline std::vector<BanRecord> ParseBanFile(std::string_view text) {
+	std::vector<BanRecord> list;
+	size_t pos = 0;
+	while (pos <= text.size()) {
+		size_t nl = text.find('\n', pos);
+		std::string_view line = text.substr(pos, nl == std::string_view::npos ? std::string_view::npos : nl - pos);
+		if (!line.empty() && line.back() == '\r')
+			line.remove_suffix(1);
+		BanRecord rec;
+		if (ParseBanLine(line, rec))
+			AddOrUpdateBan(list, rec); // dedupe on load
+		if (nl == std::string_view::npos)
+			break;
+		pos = nl + 1;
+	}
+	return list;
+}
+
+} // namespace muffmode::bans
diff --git a/src/sgame/muffmode/mm_bots_rules.h b/src/sgame/muffmode/mm_bots_rules.h
new file mode 100644
index 00000000..2199db62
--- /dev/null
+++ b/src/sgame/muffmode/mm_bots_rules.h
@@ -0,0 +1,65 @@
+// Copyright (c) ZeniMax Media Inc.
+// Licensed under the GNU General Public License 2.0.
+
+#pragma once
+
+// Pure, host-testable "drop bots when humans arrive" rules.
+//
+// The KEX engine keeps at least `bot_minClients` total clients filled with bots.
+// The game DLL cannot stop that fill directly, so this decides two things each
+// tick: what to force `bot_minClients` to, and whether to kick the bots that are
+// already present. Once `g_bot_human_cutoff` humans are connected we zero the
+// fill and kick every bot; below the cutoff we restore the server's original
+// fill so bots return. Engine-free by design; the live inputs (human count, the
+// current/cached fill) and the kick/forceset are supplied by mm_bots.cpp glue.
+
+// The server's intended bot fill is `bot_minClients`, but we overwrite that cvar
+// to 0 while suppressing bots — so the caller caches the last non-zero fill it
+// saw and threads it back in as `cached_fill` to restore later.
+struct MM_BotFillDecision {
+	bool update_fill = false; // caller should cvar_forceset bot_minClients
+	int  fill_value = 0;      // ...to this value, when update_fill is true
+	bool kick_bots = false;   // caller should kick all present bots this tick
+	int  cached_fill = 0;     // caller should persist this as the next cached fill
+};
+
+// humans       : connected human clients (bots excluded)
+// cutoff       : g_bot_human_cutoff (<= 0 disables the feature entirely)
+// current_fill : current bot_minClients value
+// cached_fill  : last non-zero fill remembered by the caller (0 = none yet)
+inline MM_BotFillDecision MM_DecideBotFill(int humans, int cutoff, int current_fill, int cached_fill) {
+	MM_BotFillDecision d;
+	d.cached_fill = cached_fill;
+
+	// Remember the desired fill whenever bots are currently allowed to fill, so
+	// we can restore it after a suppression window.
+	if (current_fill > 0)
+		d.cached_fill = current_fill;
+
+	if (cutoff <= 0) {
+		// Feature off: never leave bots suppressed. If we had zeroed the fill,
+		// restore it so bots come back.
+		if (current_fill == 0 && d.cached_fill > 0) {
+			d.update_fill = true;
+			d.fill_value = d.cached_fill;
+		}
+		return d;
+	}
+
+	if (humans >= cutoff) {
+		// Enough humans: stop refills and kick any bots already present.
+		if (current_fill != 0) {
+			d.update_fill = true;
+			d.fill_value = 0;
+		}
+		d.kick_bots = true;
+		return d;
+	}
+
+	// Below the cutoff: allow bots. Restore the cached fill if we had zeroed it.
+	if (current_fill == 0 && d.cached_fill > 0) {
+		d.update_fill = true;
+		d.fill_value = d.cached_fill;
+	}
+	return d;
+}
diff --git a/src/sgame/muffmode/mm_default_map_rules.h b/src/sgame/muffmode/mm_default_map_rules.h
new file mode 100644
index 00000000..57656dab
--- /dev/null
+++ b/src/sgame/muffmode/mm_default_map_rules.h
@@ -0,0 +1,37 @@
+// Copyright (c) ZeniMax Media Inc.
+// Licensed under the GNU General Public License 2.0.
+
+#pragma once
+
+// [KarmicP] Pure, host-testable resolution for the "default map" fallback.
+// The rotation fallback fires only when the normal g_map_list rotation produced
+// no next map (that decision is the caller's). This helper answers the narrow
+// question: given the g_default_map cvar value, what token (if any) should load?
+// It trims surrounding ASCII whitespace and returns "" when unset/blank (feature
+// off). Safety (MM_IsSafeMapToken) and the actual map change stay in mm_maps.cpp.
+
+#include <string>
+#include <string_view>
+
+inline std::string MM_ResolveDefaultMap(std::string_view default_token) {
+	size_t b = 0, e = default_token.size();
+	while (b < e && (default_token[b] == ' ' || default_token[b] == '\t'))
+		++b;
+	while (e > b && (default_token[e - 1] == ' ' || default_token[e - 1] == '\t'))
+		--e;
+	return std::string(default_token.substr(b, e - b));
+}
+
+// [KarmicP] Extract the map token from a persisted defaultmap.cfg, which is
+// written as: set g_default_map "<token>". Returns the (whitespace-trimmed)
+// content between the first pair of double quotes, or "" when absent/blank/
+// unquoted. Pure so the host harness can test it.
+inline std::string MM_ParseDefaultMapConfig(std::string_view contents) {
+	size_t q1 = contents.find('"');
+	if (q1 == std::string_view::npos)
+		return "";
+	size_t q2 = contents.find('"', q1 + 1);
+	if (q2 == std::string_view::npos)
+		return "";
+	return MM_ResolveDefaultMap(contents.substr(q1 + 1, q2 - q1 - 1));
+}
